# Agent environment variables.
# These are referenced as ${VAR} in agent.yaml.

# Gateway connection (required)
NIPPER_GATEWAY_URL=http://gateway:18789
NIPPER_AUTH_TOKEN=npr_changeme

# LLM inference
OPENAI_API_KEY=sk-changeme
INFERENCE_BASE_URL=https://api.openai.com/v1

# OpenTelemetry (optional — leave empty to disable)
OTEL_EXPORTER_OTLP_ENDPOINT=
