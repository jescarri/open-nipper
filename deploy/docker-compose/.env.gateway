# Gateway environment variables.
# These are referenced as ${VAR} in gateway.yaml.

# RabbitMQ internal queue
RABBITMQ_USERNAME=nipper
RABBITMQ_PASSWORD=changeme

# RabbitMQ Management API
RABBITMQ_MGMT_USERNAME=nipper
RABBITMQ_MGMT_PASSWORD=changeme

# Admin API token (optional, set gateway.admin.auth.enabled: true to use)
ADMIN_API_TOKEN=changeme

# OpenTelemetry (optional — leave empty to disable)
OTEL_EXPORTER_OTLP_ENDPOINT=
